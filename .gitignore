# Claude Code local user settings (not shared across team)
.claude/settings.local.json

# Secrets — methodology dogfoods its own protection (v4.34.1+, closes G-014).
# Canonical store: .env (per-project) + ~/.config/it-dev/secrets.env (shared).
# Whitelist: .env.example (committed template, never contains real values).
.env
.env.*
!.env.example
!.env.*.template
secrets.local.*
.env.lock
.env.tmp.*

# Cloud provider credential directories — contain key files (JSON, PEM, etc.), NEVER commit.
# Managed via methodology file-type secrets (secrets-manifest.yaml type: file).
.gcp/
# .aws/
# .azure/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Test outputs
/tmp/

# Scratch files (mermaid URL generation via py scripts/mermaid-link.py)
.tmp-mermaid.*

# Project artifacts (NOT for methodology-platform consumers)
# Canonical templates for consumers are in templates/
# Restored by: bash scripts/sync-methodology.sh .
rules/
CLAUDE.md
CLAUDE_LONG.md
DEVLOG.md
AGENT-GAPS.md
PRODUCT.md
PRODUCT_LONG.md
VISION.md
VISION_LONG.md
USER-MAP.md
IDEAS.md
ROADMAP.md
HYPOTHESES.md
RISKS.md
OPEN-QUESTIONS.md
BEHAVIOR.md

# ⚠️ Un-ignore command/template sources: the artifact-doc patterns above are
# unanchored and case-insensitive on Windows, so `VISION.md` accidentally matches
# `commands/vision.md` (the /vision command source). Command sources are canon —
# never ignore them. Closes the case-collision class (G-123).
!commands/**
!commands-local/**
!templates/**

# Consumer project docs (not canonical for methodology-platform):
docs/product/
docs/adr/
docs/vision/
docs/sync-vision-reports/
docs/data-map.md
docs/glossary.md
docs/BEHAVIOR.md
docs/threat-model.template.md
docs/architecture/

# Project state (local only)
.claude/state/
.claude/.version
.claude/settings.json
.claude/agents/

# Claude Code derivative files (restored by: bash scripts/new-project-init.sh .)
.claude/commands/
.claude/hooks/
.claude/model-tiers.md

# Personal Claude Code memory (never share)
.claude/projects/

# Consumer project clones (local only — cloned manually, never committed)
consumers/repos/
consumers/*.token


