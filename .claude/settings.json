{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm-rf*)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(rd *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.config/it-dev/secrets.env)",
      "Read(~/.config/it-dev/*.env)",
      "Read(./secrets.local.*)",

      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(grep * .env*)",
      "Bash(grep -* .env*)",
      "Bash(sed * .env*)",
      "Bash(sed -* .env*)",
      "Bash(awk * .env*)",
      "Bash(head .env*)",
      "Bash(head -* .env*)",
      "Bash(tail .env*)",
      "Bash(tail -* .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(strings .env*)",
      "Bash(xxd .env*)",
      "Bash(od .env*)",
      "Bash(base64 .env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/protect.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/bash_protect.py" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/docs_reminder.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/post-edit-watchdog.py" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/agent-gaps-watchdog.py" }
        ]
      }
    ]
  }
}
