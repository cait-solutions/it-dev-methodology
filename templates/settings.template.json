{
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.config/it-dev/secrets.env)",
      "Read(~/.config/it-dev/*.env)",
      "Read(./secrets.local.*)",

      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(cat ~/.config/it-dev/*)",
      "Bash(less .env*)",
      "Bash(less ./.env*)",
      "Bash(more .env*)",
      "Bash(more ./.env*)",
      "Bash(head .env*)",
      "Bash(head -* .env*)",
      "Bash(head ./.env*)",
      "Bash(tail .env*)",
      "Bash(tail -* .env*)",
      "Bash(tail ./.env*)",
      "Bash(xxd .env*)",
      "Bash(xxd ./.env*)",
      "Bash(od .env*)",
      "Bash(od -* .env*)",
      "Bash(strings .env*)",
      "Bash(hexdump .env*)",
      "Bash(hexdump -* .env*)",
      "Bash(base64 .env*)",
      "Bash(base64 ./.env*)",
      "Bash(md5sum .env*)",
      "Bash(sha1sum .env*)",
      "Bash(sha256sum .env*)",
      "Bash(awk * .env*)",
      "Bash(awk -* .env*)",
      "Bash(grep * .env*)",
      "Bash(grep -* .env*)",
      "Bash(sed * .env*)",
      "Bash(sed -* .env*)",
      "Bash(cut -* .env*)",
      "Bash(tr * .env*)",
      "Bash(shuf .env*)",
      "Bash(paste .env*)",
      "Bash(dd if=.env*)",
      "Bash(dd if=./.env*)",

      "Bash(python *.env*)",
      "Bash(python -* *.env*)",
      "Bash(python3 *.env*)",
      "Bash(python3 -* *.env*)",
      "Bash(py *.env*)",
      "Bash(py -* *.env*)",
      "Bash(node *.env*)",
      "Bash(node -* *.env*)",
      "Bash(nodejs *.env*)",
      "Bash(ruby *.env*)",
      "Bash(ruby -* *.env*)",
      "Bash(perl *.env*)",
      "Bash(perl -* *.env*)",
      "Bash(php *.env*)",
      "Bash(deno *.env*)",
      "Bash(bun *.env*)",

      "Bash(diff *.env*)",
      "Bash(diff -* *.env*)",
      "Bash(cmp *.env*)",
      "Bash(iconv *.env*)",
      "Bash(iconv -* *.env*)",
      "Bash(nl *.env*)",
      "Bash(pr *.env*)",
      "Bash(expand *.env*)",
      "Bash(unexpand *.env*)",
      "Bash(tee *.env*)",
      "Bash(tee -* *.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh protect.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh bash_protect.py" },
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh secrets-guard.py" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh docs_reminder.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh post-edit-watchdog.py" },
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh iteration-watchdog.py" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh agent-gaps-watchdog.py" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "sh .claude/hooks/hook-liveness.sh" },
          { "type": "command", "command": "sh .claude/hooks/maps-freshness-liveness.sh" },
          { "type": "command", "command": "sh .claude/hooks/run-hook.sh auto-update-watchdog.py" }
        ]
      }
    ]
  }
}
