# Workspace siblings — repos cloned inside this workspace, not project-owned.
# These live physically inside [project-name]-documentation/ but are gitignored
# so only methodology artifacts are committed to this repo.
it-dev-methodology/
# Add your code repos below, e.g.:
# [project-name]-backend/
# [project-name]-frontend/

# Claude Code — local user settings (per CLAUDE.md, not shared with team)
.claude/settings.local.json

# Methodology runtime — synced from it-dev-methodology, not project-owned.
# Run scripts/sync-methodology.sh after each git clone to restore these locally.
.claude/commands/
.claude/hooks/
.claude/model-tiers.md
.claude/.version

# Methodology local state — per-developer counters, not shared
.claude/state/

# Operating system
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*~
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/

# Secrets (managed via methodology secrets-management — see skills/secrets-management/)
# Canonical store: .env (per-project) + ~/.config/it-dev/secrets.env (shared).
# Whitelist: .env.example, .env.*.template (templates are safe to commit).
# NEVER remove these lines without rotating affected tokens first.
.env
.env.*
!.env.example
!.env.*.template
secrets.local.*
.env.lock
.env.tmp.*

# Cloud provider credential directories — contain key files (JSON, PEM, etc.), NEVER commit.
# These are managed via methodology file-type secrets (secrets-manifest.yaml type: file).
# The env var (e.g. GOOGLE_APPLICATION_CREDENTIALS) stores the PATH; the file is gitignored.
.gcp/
# .aws/        # AWS credentials dir (if not using default ~/.aws)
# .azure/      # Azure credentials dir (if not using default ~/.azure)

# Node
node_modules/
npm-debug.log
yarn-error.log

# Go
/bin/
dist/

