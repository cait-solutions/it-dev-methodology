# Secrets (managed via methodology secrets-management — see skills/secrets-management/)
# Canonical store: .env (per-project) + ~/.config/it-dev/secrets.env (shared).
# Whitelist: .env.example, .env.*.template (templates are safe to commit).
# NEVER remove these lines without rotating affected tokens first.
.env
.env.*
!.env.example
!.env.*.template
secrets.local.*
.env.lock
.env.tmp.*

# Cloud provider credential directories — contain key files (JSON, PEM, etc.), NEVER commit.
# These are managed via methodology file-type secrets (secrets-manifest.yaml type: file).
# The env var (e.g. GOOGLE_APPLICATION_CREDENTIALS) stores the PATH; the file is gitignored.
.gcp/
# .aws/        # AWS credentials dir (if not using default ~/.aws)
# .azure/      # Azure credentials dir (if not using default ~/.azure)

