.claude/settings.local.json

# Methodology runtime layer — synced from it-dev-methodology.
# commands/, hooks/, model-tiers.md (+ skills/, agents/) ARE committed (v7.8.2+):
# a fresh `git clone` of this repo must have working commands/hooks WITHOUT a manual
# sync step. They stay derived (canon = it-dev-methodology) — DO NOT edit directly,
# sync overwrites them. Only the per-clone version marker + per-developer runtime
# counters stay local (rewritten every sync / machine-specific → committing = noise):
.claude/.version

# Methodology local state — per-developer counters, not shared
.claude/state/

