# .env.example — template (commit-safe; copy to .env and fill in values)
#
# Canonical secret store for {{PROJECT_NAME}}.
# This file is the TEMPLATE — committed to git, no real values.
# Real values live in `.env` (gitignored) — copy this file:
#
#     cp .env.example .env
#     # then edit .env and fill in the values
#
# To check what is required vs present:
#     bash scripts/validate-secrets.sh
#
# To add or update a single secret without touching values of others:
#     bash scripts/set-secret.sh KEY value
#
# IMPORTANT: agents NEVER read .env directly. They use:
#     bash scripts/with-secret.sh KEY -- <command>      # inject as env, run cmd
#     bash scripts/check-secret.sh KEY                  # boolean exists check
# This way secret values never enter agent's tool output / transcript.
#
# Lookup priority (first match wins):
#   1. ./.env                                 (per-project, this file)
#   2. ~/.config/it-dev/secrets.env           (cross-project shared, optional)
#   3. process environment variables          (CI/CD compatibility)
#
# Format rules:
#   - KEY=value                               (no spaces around =)
#   - KEY="value with spaces"                 (double quotes for spaces/special chars)
#   - One key per line. No multi-line values.
#   - Lines starting with # are comments.
#
# ---------------------------------------------------------------------------
# Required keys (see .claude/secrets-manifest.yaml for full schema + how_to_obtain)
# ---------------------------------------------------------------------------

# GitHub Personal Access Token — for git push / pull via HTTPS
# Get one: https://github.com/settings/tokens (scope: repo)
GITHUB_PAT=

# Anthropic API key (optional — only if project hits Anthropic SDK directly)
# Get one: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

