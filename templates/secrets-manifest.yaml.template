# secrets-manifest.yaml — declares which secrets {{PROJECT_NAME}} needs.
#
# WHY this file exists:
#   - Single source of truth: WHAT secrets the project uses + HOW to obtain each.
#   - Agent reads this BEFORE operations. If a secret is missing, agent shows
#     `how_to_obtain` to the user and blocks until set — no repeated "give me token" loops.
#   - `/secrets --audit` compares this manifest vs actual .env state.
#
# This file IS committed to git. It contains NO secret VALUES — only names, purposes, instructions.
#
# Schema version (bump on breaking schema changes):
manifest_version: 1

# Configurable values (override defaults — all optional):
config:
  # Entropy threshold for plaintext-token detection in /review (Shannon bits/char).
  # Higher = stricter (more false positives). Default 4.5 catches most real tokens.
  entropy_threshold: 4.5

  # Token prefix patterns — extends built-in detector (ghp_, sk-, xoxb-, AKIA, ya29.).
  # Add project-specific token prefixes here. Format: regex strings.
  extra_patterns: []
  # Example:
  # extra_patterns:
  #   - "myco_[a-zA-Z0-9]{32,}"
  #   - "internal-key-[A-Z0-9]+"

  # Pre-commit hook enabled? Set false ONLY for offline/CI environments
  # where pre-commit must be skipped. /review detector still catches leaks.
  hook_enabled: true

  # Shared secrets path (cross-project). Override if not using default.
  shared_path: "~/.config/it-dev/secrets.env"

  # Paths where /secrets --scrub looks for historical exposure (transcripts/logs).
  scrub_paths:
    - "~/.claude/projects/"

# ---------------------------------------------------------------------------
# Required secrets — one entry per key.
# Schema per entry:
#   key:             ENV-style name (UPPER_SNAKE_CASE), must match .env line
#   purpose:         one-line "what this is used for"
#   required:        true | false  (false = optional, only blocks if explicitly requested)
#   scope:           per-project | shared  (where it should live; agent enforces)
#   sensitivity:     high | medium | low  (high disallows scope:shared)
#   token_pattern:   regex matching real tokens of this type (for /review detector)
#                    Use null if the secret has no recognizable prefix (e.g. DB password).
#   how_to_obtain:   |
#                    Plain-text instructions shown to user when key is missing.
#                    Keep it concise — 2-5 lines. Include URL + scopes/permissions.
# ---------------------------------------------------------------------------
secrets:
  - key: GITHUB_PAT
    purpose: "git push/pull to GitHub via HTTPS; used by deploy-push.sh and pull-consumers"
    required: true
    scope: shared
    sensitivity: high
    token_pattern: "ghp_[A-Za-z0-9]{36,}"
    how_to_obtain: |
      1. Open https://github.com/settings/tokens
      2. Click "Generate new token (classic)"
      3. Scopes: repo (full), workflow (if you push CI changes)
      4. Copy the ghp_... value
      5. Run: bash scripts/set-secret.sh GITHUB_PAT <paste-value-here>
      After this, no agent will ask for this token again in any session.

  # Example optional secret — uncomment and adapt as needed:
  # - key: ANTHROPIC_API_KEY
  #   purpose: "Anthropic SDK calls from project code (not from Claude Code itself)"
  #   required: false
  #   scope: shared
  #   sensitivity: high
  #   token_pattern: "sk-ant-[A-Za-z0-9_-]{32,}"
  #   how_to_obtain: |
  #     1. Open https://console.anthropic.com/settings/keys
  #     2. Create Key → copy sk-ant-... value
  #     3. Run: bash scripts/set-secret.sh ANTHROPIC_API_KEY <paste-value>
