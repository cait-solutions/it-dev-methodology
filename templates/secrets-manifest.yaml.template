# secrets-manifest.yaml — declares which secrets {{PROJECT_NAME}} needs.
#
# WHY this file exists:
#   - Single source of truth: WHAT secrets the project uses + WHERE they apply
#     + HOW to obtain each.
#   - Agent reads this BEFORE operations. If a secret is missing, agent shows
#     `how_to_obtain` to the user and blocks until set — no repeated "give me
#     token" loops.
#   - `/secrets --audit` compares this manifest vs actual .env state.
#   - Metadata (service_name / service_url / login) is HUMAN-readable view +
#     enables git-credential-from-env.sh to route credentials by hostname
#     (multi-host support — closes G-053).
#
# This file IS committed to git. It contains NO secret VALUES — only names,
# metadata, instructions.
#
# Schema version (bump on breaking schema changes):
manifest_version: 2

# ---------------------------------------------------------------------------
# Schema v2 (v4.41.0+) — per-entry fields:
#
#   key:             ENV-style name (UPPER_SNAKE_CASE), must match .env line
#   purpose:         one-line "what this is used for"
#   required:        true | false  (false = optional, only blocks if requested)
#
#   service_name:    [recommended v2+] Human-readable name of the service.
#                    Examples: "GitHub (cait-solutions)", "GitLab Nexchance",
#                              "OpenAI API", "AWS production".
#                    Shown in /secrets --list, --show, --audit outputs.
#
#   service_url:    [recommended v2+] URL or hostname of the service.
#                    Examples: "https://github.com", "https://code.nexchance.de",
#                              "https://api.openai.com", "https://api.anthropic.com".
#                    For git secrets — used by git-credential-from-env.sh to
#                    match requests by hostname (multi-host routing).
#                    For non-git secrets — informational (where to use it).
#
#   login:           [optional] Username / email / account ID for systems that
#                    require both username + token. Examples: "vb@nexchance.de",
#                    "oauth2" (default for GitHub PAT auth), "AKIA..." (AWS).
#                    Blank if service uses token-only auth.
#
#   expires_at:      [optional] ISO-8601 date when token expires.
#                    Example: "2026-08-15". /secrets --audit warns within
#                    `expiry_warn_days` (default 7, configurable in
#                    CLAUDE.local.md ## Secrets).
#
#   last_rotated:    [auto-managed] ISO-8601 timestamp when value was last
#                    updated via set-secret.sh. Don't edit manually.
#                    /secrets --audit warns if older than `rotation_warn_days`
#                    (default 90, configurable).
#
#   how_to_obtain_verified_at:
#                    [optional] ISO-8601 date when YOU last verified that the
#                    how_to_obtain instructions still work (URL valid, scopes
#                    still exist). Set via /secrets --verify-link KEY after
#                    you've checked. /secrets --audit warns if older than
#                    `how_to_obtain_warn_days` (default 180, configurable).
#
#   gh_account:      [optional] GitHub CLI account name required for this repo.
#                    Used by /pull-consumers pre-flight: if active gh account
#                    does not match this value, a warning + switch command is shown.
#                    Only applies to github.com remotes using `gh` CLI credential helper.
#                    Example: "IDK-IDK", "cait-solutions". Omit for non-GitHub or PAT-only.
#
#   scope:           per-project | shared  (where it should live)
#   sensitivity:     high | medium | low   (high disallows scope:shared)
#   token_pattern:   regex matching real tokens (for /review detector).
#                    Use null if no recognizable prefix (DB password etc).
#   scope_note:      [optional] Free text re: what permissions/scopes this
#                    token has. Useful for rotation reproduction.
#                    Example: "repo, workflow (CI changes)".
#   how_to_obtain:   |
#                    Plain-text instructions shown to user when key is missing.
#                    2-5 lines. Include URL + scopes/permissions.
#
# Backward-compat: v1 entries (without service_*, login, expires_at,
# last_rotated, how_to_obtain_verified_at, scope_note) continue to work.
# Scripts gracefully handle missing fields. validate-secrets warns when
# v2-recommended fields are absent for new entries.
# ---------------------------------------------------------------------------

# Configurable values (override defaults — all optional):
config:
  # Entropy threshold for plaintext-token detection in /review (Shannon bits/char).
  entropy_threshold: 4.5

  # Extra token prefix patterns (extends built-in detector).
  extra_patterns: []

  # Pre-commit hook enabled? Set false ONLY for offline/CI where pre-commit
  # must be skipped. /review detector still catches leaks.
  hook_enabled: true

  # Shared secrets path (cross-project). Override if not using default.
  shared_path: "~/.config/it-dev/secrets.env"

  # Paths where /secrets --scrub looks for historical exposure.
  scrub_paths:
    - "~/.claude/projects/"

  # ---- Schema v2 (v4.41.0+) configurable thresholds — see also
  # CLAUDE.local.md ## Secrets section. Defaults below; per-developer
  # overrides via that section.
  expiry_warn_days: 7
  rotation_warn_days: 90
  how_to_obtain_warn_days: 180
  backup_retention_hours: 24
  default_url_scheme: "https"
  strict_schema: false           # warn vs error when v2 fields missing

  # Keychain backend (v4.42.0+, opt-in — closes G-054 at-rest gap).
  # When true, with-secret.sh checks OS keychain (encrypted at-rest) BEFORE .env:
  #   macOS    → security (Keychain, из коробки)
  #   Linux    → secret-tool (libsecret — DE-dependent, GNOME/KDE)
  #   Windows  → (DPAPI store — limited, см. skill)
  # Falls through to .env if keychain unavailable / key absent.
  # RECOMMENDED on macOS/Windows (guaranteed keychain); on Linux headless keep false.
  # Store values: macOS `security add-generic-password -s it-dev-methodology -a KEY -w VALUE`
  keychain_backend: false

# ---------------------------------------------------------------------------
# Required secrets — one entry per key.
# ---------------------------------------------------------------------------
secrets:
  # NB: НЕ объявляй секреты для платформ которые проект НЕ использует.
  # new-project-init.sh определяет платформу из `git remote get-url origin` и
  # АВТОМАТИЧЕСКИ оставляет только подходящий git-секрет (GITHUB_PAT для
  # github.com, GITLAB_* для gitlab-хостов). Если remote ещё не настроен —
  # init оставляет GITHUB_PAT закомментированным примером ниже.
  # Ложный GITHUB_PAT в GitLab-проекте → secrets-show вечно "MISSING" → путаница
  # (P-005). Push НЕ требует GITHUB_PAT при наличии gh credential helper (G-083).

  # ---- GitHub PAT — раскомментируй ТОЛЬКО если remote = github.com.
  # На github.com push обычно идёт через `gh` credential helper (gh auth login),
  # тогда этот PAT не нужен. Объявляй здесь лишь если используешь PAT-в-helper.
  # - key: GITHUB_PAT
  #   purpose: "git push/pull to GitHub via HTTPS (если не через gh credential helper)"
  #   service_name: "GitHub"
  #   service_url: "https://github.com"
  #   login: "oauth2"
  #   required: false
  #   scope: shared
  #   sensitivity: high
  #   token_pattern: "ghp_[A-Za-z0-9]{36,}"
  #   scope_note: "repo, workflow"
  #   how_to_obtain: |
  #     1. Open https://github.com/settings/tokens
  #     2. "Generate new token (classic)" → scopes: repo (full), workflow
  #     3. Copy the ghp_... value
  #     4. Run: bash scripts/set-secret.sh GITHUB_PAT
  #     NB: чаще достаточно `gh auth login` — PAT в .env не обязателен.

  # ---- Example: second GitHub account (multi-account scenario) — uncomment and adapt:
  # - key: GITHUB_SECONDARY_PAT
  #   purpose: "git fetch for repos owned by a second GitHub account"
  #   service_name: "GitHub (secondary-account)"
  #   service_url: "https://github.com"
  #   login: "secondary-account"
  #   gh_account: "secondary-account"    # ← /pull-consumers checks active gh CLI account
  #   required: false
  #   scope: per-project
  #   sensitivity: high
  #   token_pattern: "ghp_[A-Za-z0-9]{36,}"
  #   how_to_obtain: |
  #     1. Open https://github.com/settings/tokens (logged in as secondary-account)
  #     2. Generate token with scope: repo
  #     3. Run: bash scripts/set-secret.sh GITHUB_SECONDARY_PAT

  # ---- Example: second host (multi-host scenario) — uncomment and adapt:
  # - key: GITLAB_NEXCHANCE
  #   purpose: "git operations for self-hosted GitLab"
  #   service_name: "GitLab Nexchance"
  #   service_url: "https://code.nexchance.de"
  #   login: "vb@nexchance.de"
  #   required: false
  #   scope: per-project
  #   sensitivity: high
  #   token_pattern: "glpat-[A-Za-z0-9_-]{20,}"
  #   scope_note: "read_repository, write_repository"
  #   how_to_obtain: |
  #     1. Open https://code.nexchance.de/-/user_settings/personal_access_tokens
  #     2. Create token with scopes: read_repository, write_repository
  #     3. Run: bash scripts/set-secret.sh GITLAB_NEXCHANCE

  # ---- Example: API key (non-git service) — uncomment if needed:
  # - key: ANTHROPIC_API_KEY
  #   purpose: "Anthropic SDK calls from project code (not Claude Code itself)"
  #   service_name: "Anthropic API"
  #   service_url: "https://api.anthropic.com"
  #   login: ""
  #   required: false
  #   scope: shared
  #   sensitivity: high
  #   token_pattern: "sk-ant-[A-Za-z0-9_-]{32,}"
  #   how_to_obtain: |
  #     1. Open https://console.anthropic.com/settings/keys
  #     2. Create Key → copy sk-ant-... value
  #     3. Run: bash scripts/set-secret.sh ANTHROPIC_API_KEY
